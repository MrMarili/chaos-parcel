# WebSocket URL — leave as localhost for local-only dev.
# On LAN (pnpm party) the client auto-detects your machine IP from the browser.
VITE_WS_URL=ws://localhost:3001/ws
# Port of the WebSocket server when the page is served separately (Vite dev)
VITE_WS_PORT=3001
VITE_JOIN_BASE_URL=http://localhost:5173/join

# Supabase (optional — for direct client reads later)
# https://supabase.com/dashboard/project/gqntusyztblfoktqkeee/settings/api
VITE_SUPABASE_URL=https://gqntusyztblfoktqkeee.supabase.co
VITE_SUPABASE_ANON_KEY=

# Monetization — billing hits same-origin /api/billing (Vite proxies to :3001 in dev)
# Party Pass / cosmetics unlock via Stripe when the server has STRIPE_SECRET_KEY
