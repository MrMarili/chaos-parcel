PORT=3001
HOST=0.0.0.0
WS_PATH=/ws
# Comma-separated allowed browser origins (party mode also allows private LAN IPs)
CORS_ORIGIN=http://localhost:5173
JOIN_BASE_URL=http://localhost:5173/join
# PARTY_MODE=true allows any 192.168.x.x / 10.x origin — LAN only; do NOT set on public deploys
# SERVE_CLIENT=true serves client/dist from this server (use with pnpm party:prod)

# --- Public deploy (Render Free) ---
# Render injects RENDER_EXTERNAL_URL (e.g. https://chaos-parcel.onrender.com).
# CORS + JOIN_BASE_URL default from that when unset. Optional overrides:
# PUBLIC_BASE_URL=https://your-app.onrender.com
# CORS_ORIGIN=https://your-app.onrender.com
# JOIN_BASE_URL=https://your-app.onrender.com/join
# NODE_ENV=production
# SERVE_CLIENT=true

# --- Monetization (Stripe Party Pass) — required for real upgrades ---
# Create a key at https://dashboard.stripe.com/apikeys (use sk_test_… while developing).
STRIPE_SECRET_KEY=
# Optional: public URL for Checkout redirects (defaults to the request Host header).
# PUBLIC_BASE_URL=https://your-public-host.example
# STRIPE_WEBHOOK_SECRET=whsec_...
# HMAC secret for pass tokens (falls back to STRIPE_SECRET_KEY)
# PARTY_PASS_SECRET=
# Free unlock WITHOUT payment — OFF by default. Only for local engineering:
# ALLOW_DEV_PARTY_PASS=true
